{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Seeder": {
    "MovieFilePath": "..\\Backend\\Movies.json"
  },
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=MovieTree;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "MovieTreeApi",
    "Audience": "MovieTreeClient",
    "ExpiryMinutes": "10080"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "StartupTasks": {
    "RunOnStartup": false
  }
}
