{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Seeder": {
    "MovieFilePath": "../Movies.json"
  },
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=MovieTree;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "MovieTreeApi",
    "Audience": "MovieTreeClient",
    "ExpiryMinutes": "10080"
  }
}
